{
  "@context": {
    "@version": 1.1,
    "sf": "https://api.salesflare.com/vocab/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",

    "Account": {
      "@id": "sf:Account",
      "@type": "rdfs:Class",
      "rdfs:comment": "A company or organization in Salesflare CRM",
      "rdfs:subClassOf": {"@id": "schema:Organization"}
    },
    "Contact": {
      "@id": "sf:Contact",
      "@type": "rdfs:Class",
      "rdfs:comment": "A person or individual contact in Salesflare CRM",
      "rdfs:subClassOf": {"@id": "schema:Person"}
    },
    "Opportunity": {
      "@id": "sf:Opportunity",
      "@type": "rdfs:Class",
      "rdfs:comment": "A sales opportunity or deal in Salesflare CRM"
    },
    "Pipeline": {
      "@id": "sf:Pipeline",
      "@type": "rdfs:Class",
      "rdfs:comment": "A sales pipeline containing ordered stages"
    },
    "Stage": {
      "@id": "sf:Stage",
      "@type": "rdfs:Class",
      "rdfs:comment": "A step within a sales pipeline"
    },
    "Task": {
      "@id": "sf:Task",
      "@type": "rdfs:Class",
      "rdfs:comment": "A to-do or action item in Salesflare CRM",
      "rdfs:subClassOf": {"@id": "schema:Action"}
    },
    "Tag": {
      "@id": "sf:Tag",
      "@type": "rdfs:Class",
      "rdfs:comment": "A label for categorizing CRM records"
    },
    "User": {
      "@id": "sf:User",
      "@type": "rdfs:Class",
      "rdfs:comment": "A Salesflare team member",
      "rdfs:subClassOf": {"@id": "schema:Person"}
    },
    "Workflow": {
      "@id": "sf:Workflow",
      "@type": "rdfs:Class",
      "rdfs:comment": "An automation sequence triggered by CRM events"
    },
    "Meeting": {
      "@id": "sf:Meeting",
      "@type": "rdfs:Class",
      "rdfs:comment": "A calendar event or call logged in Salesflare",
      "rdfs:subClassOf": {"@id": "schema:Event"}
    },
    "Message": {
      "@id": "sf:Message",
      "@type": "rdfs:Class",
      "rdfs:comment": "An email or communication record",
      "rdfs:subClassOf": {"@id": "schema:Message"}
    },

    "id": "@id",
    "type": "@type",

    "name": {"@id": "schema:name"},
    "description": {"@id": "schema:description"},
    "domain": {"@id": "sf:domain"},
    "website": {"@id": "schema:url", "@type": "@id"},
    "picture": {"@id": "schema:image", "@type": "@id"},
    "size": {"@id": "sf:companySize"},
    "owner": {"@id": "sf:owner", "@type": "@id"},
    "tags": {"@id": "sf:tags", "@container": "@set"},
    "phone_numbers": {"@id": "schema:telephone", "@container": "@set"},
    "social_profiles": {"@id": "sf:socialProfiles", "@container": "@set"},
    "creation_date": {"@id": "schema:dateCreated", "@type": "xsd:dateTime"},
    "modification_date": {"@id": "schema:dateModified", "@type": "xsd:dateTime"},

    "firstname": {"@id": "schema:givenName"},
    "lastname": {"@id": "schema:familyName"},
    "middle": {"@id": "schema:additionalName"},
    "prefix": {"@id": "schema:honorificPrefix"},
    "suffix": {"@id": "schema:honorificSuffix"},
    "email": {"@id": "schema:email", "@container": "@set"},
    "phone_number": {"@id": "schema:telephone", "@container": "@set"},
    "account": {"@id": "sf:account", "@type": "@id"},
    "contact": {"@id": "sf:contact", "@type": "@id"},
    "opportunity": {"@id": "sf:opportunity", "@type": "@id"},

    "value": {"@id": "schema:price", "@type": "xsd:decimal"},
    "currency": {"@id": "schema:priceCurrency"},
    "probability": {"@id": "sf:winProbability", "@type": "xsd:decimal"},
    "closed_date": {"@id": "sf:closedDate", "@type": "xsd:date"},
    "lost_reason": {"@id": "sf:lostReason"},
    "stage": {"@id": "sf:stage", "@type": "@id"},

    "due_date": {"@id": "schema:scheduledTime", "@type": "xsd:dateTime"},
    "assigned_to": {"@id": "schema:agent", "@type": "@id"},
    "done": {"@id": "sf:isCompleted", "@type": "xsd:boolean"},
    "reminder": {"@id": "sf:reminderTime", "@type": "xsd:dateTime"},

    "stages": {"@id": "sf:stages", "@container": "@set"},
    "pipelines": {"@id": "sf:pipelines", "@container": "@set"},

    "role": {"@id": "schema:jobTitle"},

    "enabled": {"@id": "sf:enabled", "@type": "xsd:boolean"},
    "archived": {"@id": "sf:archived", "@type": "xsd:boolean"},
    "required": {"@id": "sf:required", "@type": "xsd:boolean"}
  }
}
